# Twilio Account Credentials
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio API Key (create at: Console > Account > API Keys)
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here

# TwiML Application SID (create at: Console > Voice > TwiML Apps)
# Set the Voice Request URL to: http://your-server/voice
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (e.g. +15551234567)
TWILIO_CALLER_ID=+1xxxxxxxxxx

PORT=3001
